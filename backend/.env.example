# Sao chép file này thành .env và điền giá trị thật (KHÔNG commit .env).
# Các biến này override giá trị mặc định trong application.yml.

# Database
DB_URL=jdbc:postgresql://localhost:5432/distribution_db
DB_USERNAME=postgres
DB_PASSWORD=change-me

# JWT - bắt buộc đổi ở môi trường thật, dùng chuỗi ngẫu nhiên đủ dài
JWT_SECRET=change-me-to-a-long-random-secret

# CORS (frontend origin)
CORS_ALLOWED_ORIGINS=http://localhost:5173
